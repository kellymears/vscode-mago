{
  "name": "vscode-mago-formatter",
  "displayName": "Mago Formatter",
  "description": "Formats PHP files using mago, respecting mago.toml excludes",
  "publisher": "kellymears",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kellymears/vscode-mago-formatter"
  },
  "categories": [
    "Formatters"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:php"
  ],
  "contributes": {
    "languages": [
      {
        "id": "php",
        "extensions": [
          ".php"
        ]
      }
    ]
  }
}
